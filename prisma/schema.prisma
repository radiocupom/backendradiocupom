generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "windows"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  superadmin
  admin
  loja
}

enum CategoriaLoja {
  RESTAURANTE
  SUPERMERCADO
  PADARIA
  LOJA_DE_ROUPAS
  ELETRONICOS
  OUTROS
}

model Usuario {
  id        String   @id @default(uuid()) @db.Uuid
  nome      String
  email     String   @unique
  senha     String
  role      Role     @default(loja)
  lojaId    String?  @unique @map("loja_id") @db.Uuid
  loja      Loja?    @relation(fields: [lojaId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([email])
  @@index([role])
  @@map("usuarios")
}

model Loja {
  id          String   @id @default(uuid()) @db.Uuid
  nome        String
  email       String   @unique
  senha       String
  logo        String
  payment     Boolean  @default(false)
  categoria   CategoriaLoja
  descricao   String
  usuario     Usuario?
  cupons      Cupom[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  ultimoLogin DateTime? @map("ultimo_login")

  @@index([payment])
  @@index([categoria])
  @@index([createdAt])
  @@index([payment, categoria])
  @@map("lojas")
}

model Cliente {
  id             String    @id @default(uuid()) @db.Uuid
  nome           String
  email          String    @unique
  senha          String
  whatsapp       String   
  bairro         String?
  cidade         String?
  estado         String?
  pais           String   @default("Brasil")
  genero         String?
  dataNascimento DateTime? @map("data_nascimento")
  instagram      String?
  facebook       String?
  tiktok         String?
  receberOfertas Boolean?   @default(true) @map("receber_ofertas")
  comoConheceu   String?   @map("como_conheceu")
  ativo          Boolean   @default(true)
  observacoes    String?   @db.Text
  resgates       Resgate[]
  qrCodesUsados  QrCodeUsado[]
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  ultimoLogin    DateTime? @map("ultimo_login")

  @@index([email])
  @@index([whatsapp])
  @@index([cidade, estado])
  @@index([dataNascimento])
  @@index([createdAt])
  @@index([ativo])
  @@map("clientes")
}
 
model Cupom {
  id                   String        @id @default(uuid()) @db.Uuid
  codigo               String        @unique
  descricao            String
  quantidadePorCliente Int           @map("quantidade_por_cliente")
  dataExpiracao        DateTime      @map("data_expiracao")
  lojaId               String        @map("loja_id") @db.Uuid
  loja                 Loja          @relation(fields: [lojaId], references: [id])
  logo                 String
  ativo                Boolean       @default(true) @map("ativo")
  
  precoOriginal        Float?        @map("preco_original")
  precoComDesconto     Float?        @map("preco_com_desconto")
  percentualDesconto   Int?          @map("percentual_desconto")
  nomeProduto          String?       @map("nome_produto")
  
  totalQrCodes         Int           @default(1000) @map("total_qr_codes")
  qrCodesUsados        Int           @default(0) @map("qr_codes_usados")
  
  // Relacionamentos (SEM CASCADE AQUI!)
  resgates             Resgate[]     
  qrCodesUsadosList    QrCodeUsado[]
  
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")

  @@index([lojaId])
  @@index([dataExpiracao])
  @@index([lojaId, dataExpiracao])
  @@index([precoComDesconto])
  @@map("cupons")
}

model QrCodeUsado {
  id          String    @id @default(uuid()) @db.Uuid
  cupomId     String    @map("cupom_id") @db.Uuid
  cupom       Cupom     @relation(fields: [cupomId], references: [id], onDelete: Cascade)
  codigo      String    @unique(map: "qrcodes_usados_codigo_unique")
  clienteId   String    @map("cliente_id") @db.Uuid
  cliente     Cliente   @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  resgateId   String?   @map("resgate_id") @db.Uuid
  resgate     Resgate?  @relation(fields: [resgateId], references: [id])
  usadoEm     DateTime  @default(now()) @map("usado_em")
  validadoEm  DateTime? @map("validado_em")
  validado    Boolean   @default(false) @map("validado")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([cupomId])
  @@index([clienteId])
  @@index([usadoEm])
  @@index([validado])
  @@index([cupomId, validado])
  @@index([clienteId, validado])
  @@index([cupomId, clienteId])
  @@index([validadoEm])
  @@index([createdAt])
  @@index([cupomId, clienteId, validado])
  @@index([resgateId])
  @@map("qrcodes_usados")
}

model Resgate {
  id          String   @id @default(uuid()) @db.Uuid
  clienteId   String   @map("cliente_id") @db.Uuid
  cupomId     String   @map("cupom_id") @db.Uuid
  quantidade  Int      @default(1)
  cliente     Cliente  @relation(fields: [clienteId], references: [id])
  cupom       Cupom    @relation(fields: [cupomId], references: [id], onDelete: Cascade)  // ← CASCADE AQUI!
  resgatadoEm DateTime @default(now()) @map("resgatado_em")
  qrCodes     QrCodeUsado[]

  @@index([clienteId, cupomId])
  @@index([clienteId])
  @@index([cupomId])
  @@index([resgatadoEm])
  @@index([clienteId, resgatadoEm])
  @@index([cupomId, resgatadoEm])
  @@map("resgates")
}